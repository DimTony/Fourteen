{
  "family": "genderize-task",
  "executionRoleArn": "arn:aws:iam::012834916544:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "genderize-container",
      "image": "012834916544.dkr.ecr.eu-north-1.amazonaws.com/genderize:latest",
      "cpu": 0,
      "essential": true,
      "portMappings": [
        {
          "name": "genderize-8080-tcp",
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "healthCheck": {
       "command": ["CMD-SHELL", "curl -f http://localhost:8080/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Production"
        },
        {
          "name": "ASPNETCORE_URLS",
          "value": "http://+:8080"
        },
        {
          "name": "ExternalApi__GenderizeUrl",
          "value": "https://api.genderize.io"
        },
        {
          "name": "ExternalApi__AgifyUrl",
          "value": "https://api.agify.io"
        },
        {
          "name": "ExternalApi__NationalizeUrl",
          "value": "https://api.nationalize.io"
        },
        {
          "name": "Features__CreateProfile",
          "value": "true"
        },
        {
          "name": "Features__GetProfiles",
          "value": "true"
        },
        {
          "name": "Features__SearchProfiles",
          "value": "true"
        },
        {
          "name": "Features__GetProfileById",
          "value": "true"
        },
        {
          "name": "Features__GetAllProfiles",
          "value": "true"
        },
        {
          "name": "Features__DeleteProfile",
          "value": "true"
        },
        {
          "name": "Features__ClassifyName",
          "value": "true"
        },
        {
          "name": "Features__ProfilesEndpoint",
          "value": "true"
        },
        {
          "name": "Features__ClassifyEndpoint",
          "value": "true"
        },
        {
          "name": "Features__UserManagement",
          "value": "true"
        },
        {
          "name": "Features__GetDashboardStats",
          "value": "true"
        },
        {
          "name": "Jwt__Issuer",
          "value": "FourteenAPI"
        },
        {
          "name": "Jwt__Audience",
          "value": "FourteenAPI"
        },
        {
          "name": "Jwt__ExpirationMinutes",
          "value": "3"
        },
        {
          "name": "GitHub__WebCallbackUri",
          "value": "http://localhost:3000/dashboard"
        },
        {
          "name": "GitHub__CliCallbackUri",
          "value": "http://localhost:3000/callback"
        },
        {
          "name": "GitHub__RedirectUri",
          "value": "https://fourteen-web.vercel.app/callback"
        },
        {
          "name": "GitHub__GithubAuthUrl",
          "value": "https://github.com/login/oauth/authorize"
        },
        {
          "name": "GitHub__GithubTokenUrl",
          "value": "https://github.com/login/oauth/access_token"
        },
        {
          "name": "GitHub__GithubApiUrl",
          "value": "https://api.github.com/user"
        },
        {
          "name": "GitHub__GithubEmailsApiUrl",
          "value": "https://api.github.com/user/emails"
        },
        {
          "name": "RateLimiting__Auth__PermitLimit",
          "value": "10"
        },
        {
          "name": "RateLimiting__Auth__WindowSeconds",
          "value": "60"
        },
        {
          "name": "RateLimiting__Api__PermitLimit",
          "value": "60"
        },
        {
          "name": "RateLimiting__Api__WindowSeconds",
          "value": "60"
        },
        {
          "name": "App__AllowedOrigins",
          "value": "https://fourteen-web.vercel.app"
        }
      ],
      "secrets": [
        {
          "name": "ConnectionStrings__DefaultConnection",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/ConnectionStrings__DefaultConnection"
        },
        {
          "name": "Jwt__SecretKey",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/Jwt__SecretKey"
        },
        {
          "name": "GitHub__ClientId",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/GitHub__ClientId"
        },
        {
          "name": "GitHub__ClientSecret",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/GitHub__ClientSecret"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/genderize-task",
          "awslogs-create-group": "true",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "systemControls": []
    }
  ]
}
